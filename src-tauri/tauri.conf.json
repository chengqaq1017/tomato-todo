{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tomato Todo",
  "version": "0.1.0",
  "identifier": "com.tomato.todo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tomato Todo",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Tomato Todo contributors",
    "category": "Productivity",
    "shortDescription": "A lightweight native Pomodoro and task manager.",
    "longDescription": "Tomato Todo is an offline-first desktop productivity app with Pomodoro timing, tasks, habits, notes, and statistics.",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true
      }
    }
  }
}
